{
    "name": "DeepDive",
    "description": "Fast and easy research for AI generated responses",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "dist/public/index.html"
    },
    "content_scripts": [
        {
            "js": [
                "dist/dist.js"
            ],
            "css": [
                "dist/assets/dist.css"
            ],
            "matches": [
                "https://chatgpt.com/*",
                "https://*.google.com/search?*&deepdive=1*"
            ]
        }
    ],
    "permissions": [
        "storage"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/assets/fish.svg",
                "src/assets/water.svg",
                "src/assets/loading.svg",
                "src/assets/water_light.svg",
                "src/assets/logo_full.png",
                "src/assets/thumbs_up.svg",
                "src/assets/thumbs_up_filled.svg",
                "src/assets/thumbs_down.svg",
                "src/assets/thumbs_down_filled.svg"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "src/assets/icon_16.png",
        "32": "src/assets/icon_32.png",
        "48": "src/assets/icon_48.png",
        "128": "src/assets/icon_128.png"
    }
}