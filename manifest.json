{
    "name": "DeepDive",
    "description": "Provides research for AI generated responses",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "src/index.html"
    },
    "content_scripts": [
        {
            "js": [
                "dist/dist.js"
            ],
            "css": [
                "dist/assets/dist.css"
            ],
            "matches": [
                "https://chatgpt.com/*",
                "https://*.google.com/*"
            ]
        }
  ],
  "web_accessible_resources": [
    {
        "resources": ["src/assets/fish.svg", "src/assets/water.svg", "src/assets/loading.svg"],
        "matches": ["<all_urls>"]
    }
  ]
}